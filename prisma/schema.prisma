generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

// ─── Event (top-level container) ─────────────────────────────────────────────
model Event {
  id                String      @id @default(cuid())
  name              String
  description       String?     @db.Text
  status            EventStatus @default(UPCOMING)
  activeChallengeId String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  challenges Challenge[]
  users      User[]

  @@index([status])
}

// ─── User ─────────────────────────────────────────────────────────────────────
model User {
  id        String   @id @default(cuid())
  username  String   @unique
  name      String?
  password  String
  role      UserRole
  isActive  Boolean  @default(true)
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id])
  createdAt DateTime @default(now())

  juryVotes JuryVote[]

  @@index([eventId, role])
}

// ─── Challenge (one competition slot) ────────────────────────────────────────
model Challenge {
  id                    String          @id @default(cuid())
  eventId               String
  event                 Event           @relation(fields: [eventId], references: [id])
  name                  String
  description           String?         @db.Text
  slug                  String
  order                 Int
  status                ChallengeStatus @default(PENDING)
  phase                 ChallengePhase  @default(WAITING)
  timerSecs             Int             @default(600)
  timerActive           Boolean         @default(false)
  voteOpenAt            DateTime?
  voteCloseAt           DateTime?
  votingStartedAt       DateTime?
  votingEndsAt          DateTime?
  votingDurationSeconds Int             @default(120)
  votingSessionId       String?
  votingTimerStatus     String          @default("READY")
  votingTimerPausedAt   DateTime?
  winnerId              String?

  team1FinalScore Float?
  team2FinalScore Float?
  team1PublicPct  Float?
  team2PublicPct  Float?
  team1JuryPct    Float?
  team2JuryPct    Float?

  team1TimerDurationSeconds  Int       @default(600)
  team1TimerRemainingSeconds Int       @default(600)
  team1TimerStatus           String    @default("READY")
  team1TimerStartedAt        DateTime?
  team1TimerPausedAt         DateTime?

  team2TimerDurationSeconds  Int       @default(600)
  team2TimerRemainingSeconds Int       @default(600)
  team2TimerStatus           String    @default("READY")
  team2TimerStartedAt        DateTime?
  team2TimerPausedAt         DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  winner      Team?        @relation("ChallengeWinner", fields: [winnerId], references: [id])
  teams       Team[]
  publicVotes PublicVote[]
  juryVotes   JuryVote[]

  @@unique([eventId, slug])
  @@index([eventId, status])
  @@index([eventId, order])
}

// ─── Team ─────────────────────────────────────────────────────────────────────
model Team {
  id          String    @id @default(cuid())
  challengeId String
  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  name        String
  idea        String    @db.Text
  members     String?   @db.Text
  imageUrl    String?
  slot        TeamSlot
  createdAt   DateTime  @default(now())

  publicVotes   PublicVote[]
  juryVotes     JuryVote[]
  wonChallenges Challenge[]  @relation("ChallengeWinner")

  @@unique([challengeId, slot])
  @@index([challengeId])
}

// ─── PublicVote ───────────────────────────────────────────────────────────────
model PublicVote {
  id              String    @id @default(cuid())
  challengeId     String
  challenge       Challenge @relation(fields: [challengeId], references: [id])
  teamId          String
  team            Team      @relation(fields: [teamId], references: [id])
  voterToken      String
  votingSessionId String    @default("legacy")
  createdAt       DateTime  @default(now())

  @@unique([challengeId, votingSessionId, voterToken])
  @@index([challengeId, teamId])
}

// ─── JuryVote ────────────────────────────────────────────────────────────────
model JuryVote {
  id              String    @id @default(cuid())
  challengeId     String
  challenge       Challenge @relation(fields: [challengeId], references: [id])
  teamId          String
  team            Team      @relation(fields: [teamId], references: [id])
  jurorId         String
  juror           User      @relation(fields: [jurorId], references: [id])
  votingSessionId String    @default("legacy")
  createdAt       DateTime  @default(now())

  @@unique([challengeId, votingSessionId, jurorId])
  @@index([challengeId])
}

// ─── Enums ───────────────────────────────────────────────────────────────────
enum EventStatus {
  UPCOMING
  ACTIVE
  COMPLETED
}

enum ChallengeStatus {
  PENDING
  ACTIVE
  COMPLETED
}

enum ChallengePhase {
  WAITING
  PRESENTING
  VOTING
  RESULT
  FINISHED
}

enum UserRole {
  SUPERADMIN
  ADMIN
  JURY
}

enum TeamSlot {
  TEAM1
  TEAM2
}
